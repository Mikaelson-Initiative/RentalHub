# =============================================================
# RentalHub Nigeria — Frontend (template)
# The backend (API + database) lives in a SEPARATE repository.
# This app only needs public/client config + the backend API URL.
# Copy to .env.local and fill in real values.
# =============================================================

# Base URL of the backend API this frontend talks to
NEXT_PUBLIC_API_URL="https://api.rentalhub.ng"

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="RentalHub Nigeria"

# ── Paystack (PUBLIC key only — safe for the client) ───────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_your-paystack-public-key"

# ── Analytics ──────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ── Sentry (error monitoring) ──────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://your-dsn@sentry.io/your-project-id"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
